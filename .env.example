# ==========================================
# VIMIND ENVIRONMENT VARIABLES FOR PRODUCTION
# ==========================================

# --- Backend Configs ---
DATABASE_URL=your-postgresql-database-url
GEMINI_API_KEY=your-gemini-api-key
SUPABASE_URL=your-supabase-project-url
# Paste the JWKS JSON string here
SUPABASE_JWKS_JSON={"keys":[{"alg":"ES256","crv":"P-256","ext":true,"key_ops":["verify"],"kid":"...","kty":"EC","use":"sig","x":"...","y":"..."}]}
FRONTEND_URL=* # Set to http://yourdomain.com in production

# --- Frontend Configs ---
# Leave empty since all endpoint paths in the code already start with /api
VITE_API_BASE_URL=
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
